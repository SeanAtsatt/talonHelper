app: Calendar
-

new event: key(cmd-n)
delete event: key(cmd-delete)
event info: key(cmd-i)
find event: key(cmd-f)

day view: key(cmd-1)
week view: key(cmd-2)
month view: key(cmd-3)
year view: key(cmd-4)

go today: key(cmd-t)
jump date: key(cmd-shift-t)
next: key(cmd-right)
back: key(cmd-left)

refresh cal: key(cmd-r)
