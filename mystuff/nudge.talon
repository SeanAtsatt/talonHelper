nudge up <number>:
    x = mouse_x()
    y = mouse_y()
    mouse_move(x, y - number)
nudge down <number>:
    x = mouse_x()
    y = mouse_y()
    mouse_move(x, y + number)
nudge left <number>:
    x = mouse_x()
    y = mouse_y()
    mouse_move(x - number, y)
nudge right <number>:
    x = mouse_x()
    y = mouse_y()
    mouse_move(x + number, y)