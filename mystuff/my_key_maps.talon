# alt=option,super=command, ctrl=control
# cursorless
# to start: "draft this/all/line"
# to end: "draft submit/discard"
# You can do "draft submit" multiple times for the most recent draft.
# cursorless tutorial

# talon
# talon open log


#screen to clipboard: key(ctrl-shift-super-3)
#selection to clipboard: key(ctrl-shift-super-4)

# in settings.talon
#user.talon_hud_allows_capture = false
#user.context_sensitive_dictation 
#whisper command: key(alt-0)
Done: key(return) 
Put: key(super-return)
Link:
  key(f9)
Gram:
  key(f8)
Lumos:
  key(ctrl-alt-cmd-c)
Encrypt:
  key(super-f3)
Decrypt:
  key(super-f4)
open:
  key(super-o)
close:
  user.close_confirm_start()
save:
  key(super-s)
quit:
  key(super-q)
view markdown:
  key(super-shift-v)
collapse all:
  key(super+k super+0)
expand all:
  key(super+k super+j)
collapse section:
  key(super+shift+[)
expand section:
  key(super+shift+])


