app: QuickTime Player
-

^(play | pause)$ : key(space)
go back one: key(left)
go forward one: key(right)
louder : key(up)
quieter: key(down)
seek forward: key(right)
seek backward: key(left)
go start: key(alt-left)
go end: key(alt-right)
rewind faster: key(super-left)
forward faster: key(super-right)


